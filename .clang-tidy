# Repo-level clang-tidy configuration. Adjust checks here to change CI/local behavior.
# Enable ALL checks, then disable noisy and style-only ones
Checks: >
  *,
  -modernize-use-trailing-return-type,
  
# Run checks on both SDK headers and test source/headers
HeaderFilterRegex: '.*pkr_units[\\/].*|.*tests[\\/].*'

# Note: CI/build may override this file if CLANG_TIDY_CHECKS is explicitly set
# via environment. Prefer editing this file to tune behavior for the repo.

  # -readability-identifier-length,
  # -readability-redundant-string-init,
  # -llvm-header-guard,
